// Prisma schema for PostgreSQL database
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// User model for authentication and profile management
model User {
  id                String   @id @default(cuid())
  email             String   @unique
  passwordHash      String
  username          String?  @unique
  displayName       String   @default("")
  bio               String   @default("") @db.VarChar(500)
  avatar            String   @default("")
  favoriteGame      String   @default("")
  profileCompleted  Boolean  @default(false)
  role              String   @default("user") // 'user' or 'admin'
  
  // Stats
  stats             UserStats?
  
  // Relationships
  scores            Score[]
  followers         Follow[]  @relation("Followers")
  following         Follow[]  @relation("Following")
  gameSessions      GameSession[]
  wordGameSessions  WordGameSession[]
  memoryGameSessions MemoryGameSession[]
  gameData          GameData[]
  
  // Metadata
  meta              Json      @default("{}")
  createdAt         DateTime  @default(now())
  lastLogin         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@index([email])
  @@index([username])
  @@index([createdAt])
}

// User statistics
model UserStats {
  id                String   @id @default(cuid())
  userId            String   @unique
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  followerCount     Int      @default(0)
  followingCount    Int      @default(0)
  totalScore        Int      @default(0)
  gamesPlayed       Int      @default(0)
  
  updatedAt         DateTime @updatedAt

  @@index([userId])
}

// Score model for game scores and leaderboard
model Score {
  id                String   @id @default(cuid())
  game              String   // Game type identifier
  userId            String?
  user              User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  
  playerName        String   @default("guest")
  score             Int
  meta              Json     @default("{}")
  
  createdAt         DateTime @default(now())

  @@index([game])
  @@index([userId])
  @@index([game, score(sort: Desc)])
  @@index([playerName])
  @@index([createdAt])
}

// Follow relationship for social features
model Follow {
  id                String   @id @default(cuid())
  followerId        String
  follower          User     @relation("Following", fields: [followerId], references: [id], onDelete: Cascade)
  
  followingId       String
  following         User     @relation("Followers", fields: [followingId], references: [id], onDelete: Cascade)
  
  createdAt         DateTime @default(now())

  @@unique([followerId, followingId])
  @@index([followerId])
  @@index([followingId])
}

// Word model for word games
model Word {
  id                String   @id @default(cuid())
  word              String   @unique
  category          String   @default("General")
  difficulty        String   @default("beginner") // beginner, intermediate, advanced, expert, master
  language          String   @default("english")
  description       String
  definition        String?
  pronunciation     String?
  etymology         String?
  examples          String[] @default([])
  hints             String[] @default([])
  frequency         Int      @default(50) // 0-100 popularity score
  status            String   @default("active") // active, inactive
  
  // Metadata
  usageCount        Int      @default(0)
  lastUsed          DateTime?
  verifiedAt        DateTime?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([category])
  @@index([difficulty])
  @@index([language])
  @@index([status])
}

// Game session model for tracking game progress
model GameSession {
  id                String   @id @default(cuid())
  sessionId         String   @unique
  game              String   // Game type identifier
  userId            String?
  user              User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  
  difficulty        String?
  gameMode          String?
  category          String?
  
  state             Json     @default("{}") // Current game state
  meta              Json     @default("{}") // Game-specific metadata
  
  startedAt         DateTime @default(now())
  completedAt       DateTime?
  duration          Int?     // Duration in milliseconds
  
  completed         Boolean  @default(false)
  score             Int      @default(0)
  
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([game])
  @@index([userId])
  @@index([sessionId])
  @@index([completed])
  @@index([startedAt])
}

// Word game session for word scramble, word builder, word guess
model WordGameSession {
  id                String   @id @default(cuid())
  sessionId         String   @unique
  userId            String?
  user              User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  
  gameType          String   // word-scramble, word-builder, word-guess
  difficulty        String   @default("medium")
  category          String?
  
  words             String[]
  currentWordIndex  Int      @default(0)
  
  score             Int      @default(0)
  moves             Int      @default(0)
  hintsUsed         Int      @default(0)
  correctGuesses    Int      @default(0)
  
  state             Json     @default("{}") // Current game state
  meta              Json     @default("{}") // Additional metadata
  
  startedAt         DateTime @default(now())
  completedAt       DateTime?
  completed         Boolean  @default(false)
  
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([gameType])
  @@index([userId])
  @@index([sessionId])
  @@index([completed])
}

// Memory game session
model MemoryGameSession {
  id                String   @id @default(cuid())
  sessionId         String   @unique
  userId            String?
  user              User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  
  difficulty        String   @default("easy") // easy, medium, hard
  theme             String   @default("fruits")
  
  cards             Json     // Card array stored as JSON
  flips             Json     @default("[]")
  matches           Int      @default(0)
  totalPairs        Int
  moves             Int      @default(0)
  score             Int      @default(0)
  
  state             Json     @default("{}") // Current game state
  meta              Json     @default("{}") // Additional metadata
  
  startedAt         DateTime @default(now())
  completedAt       DateTime?
  completed         Boolean  @default(false)
  
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([userId])
  @@index([sessionId])
  @@index([completed])
}

// Generic game-specific session data store
model GameData {
  id                String   @id @default(cuid())
  game              String   // Game type
  key               String   // Data key
  value             Json     // Data value
  userId            String?
  user              User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  
  expiresAt         DateTime? // For temporary data
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@unique([game, key, userId])
  @@index([game])
  @@index([userId])
  @@index([expiresAt])
}
